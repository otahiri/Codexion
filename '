#include "codexion.h"

int	is_space(char c)
{
	if (c == ' ' || (c >= 9 && c <= 13))
		return (1);
	return (0);
}

int	ft_atoi(char *num)
{
	while (*num && is_space(*num))
		num++;

	while (*num)
	{

		num++;
	}
}
